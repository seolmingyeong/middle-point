{
  "name": "Python 3",

  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py"
      ]
    },

    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo xargs apt install -y < packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; echo '✅ Environment Ready'",

  "postAttachCommand": {
    "server": "streamlit run app.py"
  },

  "forwardPorts": [8501],

  "portsAttributes": {
    "8501": {
      "label": "Spacetime App",
      "onAutoForward": "openPreview"
    }
  }
}